def summarize_and_filter_hmm_result(file, evalue=1e-10, targetThreshold = 0.7, hmmCov = 0.35):
# read in dataframe from processed hmm domtblout file
    df = pd.read_csv(file, sep="\t", header=None, 
                     names=["targetName", "targetLength", "queryName", "queryLength", "evalue", "qFrom", "qTo", "tFrom", "tTo"])
    # filter by evalue threshold
    
    print("Processing hmmsearch results from sample {file}".format(file = file))
    print("Starting with {} rows which contain {} unique reads aligned to {} HMM profiles.".format(df.shape[0], df["targetName"].unique().shape[0], df["queryName"].unique().shape[0]))
    df = df[df.evalue < evalue]
    print("Rows after filtering for evalue < {evalue}: {rows}".format(evalue = evalue , rows = df.shape[0]))
    # filter for reads that are at least x percent aligned to hmm 
    df = df[(df.tTo -df.tFrom)/df.targetLength > targetThreshold]
    print("Rows after filtering for read which aligned to > {targetThreshold}: {rows}".format(targetThreshold = targetThreshold , rows = df.shape[0]))
    # filter duplicate reads, only keep best hit by evalue
    df = df.loc[df.groupby('targetName')['evalue'].idxmin()]
    print("Rows after removing duplicate reads: {rows}".format(rows = df.shape[0]))
    # remove .hmmm
    df['queryName'] = df['queryName'].str.replace('.hmm', '')
    df["alnLen"] = df["qTo"] -df["qFrom"]
    grouped = df.sort_values(by=["queryName", "qFrom", "qTo"]).groupby('queryName')
    
    result_dict ={}
    for group, group_data in grouped:
        hmmLength = group_data.iloc[0,3]
        countAlignedReads = group_data["qFrom"].count()
        nAlignedBases = group_data["alnLen"].sum()
        ngaps = 0
        lenGaps = 0
        start = group_data["qFrom"].min()
        end = group_data["qTo"].max()
        
        # iterate rows to check for gaps
        for index, row in group_data.iterrows():
            if index + 1 < len(group_data):
                current_row = group_data.iloc[index]
                next_row = group_data.iloc[index +1]
                if (next_row["qFrom"] > current_row["qTo"]): 
                    gap_size =  gapsize + next_row["qFrom"] - current_row["qTo"]
                    ngaps += 1
                    
        hmmCoveredLength = round((end - start - lenGaps) / hmmLength , 2)
        hmmCoverage = round(nAlignedBases / hmmLength, 2)

        result_dict[group] = [hmmLength, countAlignedReads,  nAlignedBases, ngaps, lenGaps, hmmCoveredLength, hmmCoverage]

    res = pd.DataFrame.from_dict(result_dict, orient='index', 
                       columns= ["hmmLength", "countAlignedReads", "nAlignedBases", "ngaps", "lenGaps", "hmmCoveredLength", "hmmCoverage"])
    print("Hmm before filtering for hmm coverage: ", res.shape[0])
    res = res[res.hmmCoveredLength > hmmCov]
    print("Hmm with coverage > ", hmmCov, ": " ,res.shape[0])
    print("==================")
    return(res)



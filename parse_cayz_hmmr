def rpk(row):
    rpk = row["nAlignedBases"]/ row["hmmLength"] * 1000 / 3
    return(round(rpk,2))


def tpm(row, rpk_sum):
    tpm = row["rpk"]/(rpk_sum/1e6)
    return(round(tpm,2))


def rpkm(row, summedreads):
    scale = summedreads/1e6
    rpm = row["nAlignedBases"]/scale
    rpkm = rpm / row["hmmLength"] /(1000/3)
    return(round(rpkm,2))


def filter_kofamscan_result(df, evalue=1e-10):
# read in dataframe from processed hmm domtblout file

    print("Starting with {} rows which contain {} unique contigs aligned to {} KO HMM profiles.".format(df.shape[0], 
                                                                                                   df["GeneName"].unique().shape[0], 
                                                                                                   df["KO"].unique().shape[0]))
    # filter for hites where score is lager than scire threshold
    df = df[df.threshold <= df.score]
    print("Rows after filtering for score>=threshold: {rows}".format(rows = df.shape[0]))
    # filter fir evalue threshold
    df = df[df.evalue < evalue]
    print("Rows after filtering for evalue < {evalue}: {rows}".format(evalue = evalue , rows = df.shape[0]))
    # modify gene name
    df['GeneName'] = df['GeneName'].str.replace(r'_[0-9]+$', '')
    # filter duplicate reads, only keep best hit by evalue, set index first
    df.index = np.arange(1, len(df) + 1)
    df = df.loc[df.groupby('GeneName')['evalue'].idxmin()]
    print("Rows after removing duplicate reads: {rows}".format(rows = df.shape[0]))

    return(df)


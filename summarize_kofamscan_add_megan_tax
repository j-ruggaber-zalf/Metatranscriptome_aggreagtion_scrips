# Function to parse each taxonomic string and extract data into a dictionary
def parse_tax_string(tax_string):
    tax_dict = {}
    if isinstance(tax_string, str):  # Ensure the value is a string
        for item in tax_string.split(';'):
            item = item.strip()
            if item:
                key = item[1]  # The letter within the brackets
                value = item[4:]  # The taxonomic level
                tax_dict[key] = value
    return tax_dict


